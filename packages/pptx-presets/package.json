{
  "name": "@civilization-os/pptx-presets",
  "version": "0.1.0",
  "description": "Reusable PPTX template presets for presentation generators.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
