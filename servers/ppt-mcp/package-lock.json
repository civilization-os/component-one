{
  "name": "ppt-mcp",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ppt-mcp",
      "version": "0.1.0",
      "dependencies": {
        "@civilization-os/ppt": "file:../../packages/ppt",
        "component-one": "file:../.."
      }
    },
    "../..": {
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "devDependencies": {
        "@types/node": "^22.15.31",
        "typescript": "^5.5.0"
      }
    },
    "../../packages/ppt": {
      "name": "@civilization-os/ppt",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "zod": "^3.23.8"
      },
      "optionalDependencies": {
        "pptxgenjs": "^3.12.0"
      }
    },
    "node_modules/@civilization-os/ppt": {
      "resolved": "../../packages/ppt",
      "link": true
    },
    "node_modules/component-one": {
      "resolved": "../..",
      "link": true
    }
  }
}
